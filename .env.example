# NFT Market Analytics API - Environment Variables
# ================================================
# 
# IMPORTANT: Do NOT commit the actual .env file to git!
# This is an example template showing all required variables.
#
# To use:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values
# 3. Never commit .env to version control
#

# ═══════════════════════════════════════════════════════════════════════════════
# API KEYS (REQUIRED)
# ═══════════════════════════════════════════════════════════════════════════════
# Generate strong random keys for each mobile app
# Example: openssl rand -hex 32
# Or use: https://www.uuidgenerator.net/

# First mobile app API key (generate with: openssl rand -hex 32)
API_KEY_APP1=your_api_key_app1_here

# Second mobile app API key (generate with: openssl rand -hex 32)
API_KEY_APP2=your_api_key_app2_here


# ═══════════════════════════════════════════════════════════════════════════════
# DATA CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Path to directory containing CSV files
# Relative path from project root: data
# Absolute path: /Users/mahesh/github/NFT-project/data

DATA_PATH=data

# Optional: CSV file URLs (used when local files are missing)
# You can paste Google Drive share links here; code will convert them to
# direct-download links automatically.
# Example share link: https://drive.google.com/file/d/<FILE_ID>/view?usp=sharing

DATA_URL_LEVEL3_CRYPTOPUNKS=
DATA_URL_LEVEL3_BAYC=
DATA_URL_LEVEL3_MAYC=
DATA_URL_LEVEL3_DOODLES=
DATA_URL_LEVEL3_PUDGY_PENGUINS=

DATA_URL_LEVEL4_CRYPTOPUNKS=
DATA_URL_LEVEL4_BAYC=
DATA_URL_LEVEL4_MAYC=
DATA_URL_LEVEL4_DOODLES=
DATA_URL_LEVEL4_PUDGYPENGUINS=


# ═══════════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Port to run API on (default: 8000)
PORT=8000

# Host to bind to (0.0.0.0 for public access, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# Environment (development, staging, production)
ENV=development
